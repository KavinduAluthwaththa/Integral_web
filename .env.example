# Public Supabase client (frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-only, keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site base URL (used for redirects/links)
NEXT_PUBLIC_SITE_URL=https://your-site-url.com

# PayHere configuration
PAYHERE_MERCHANT_ID=your-merchant-id
PAYHERE_MERCHANT_SECRET=your-merchant-secret
PAYHERE_MODE=sandbox # or live
PAYHERE_RETURN_URL= # optional override, defaults to {SITE_URL}/checkout/success
PAYHERE_CANCEL_URL= # optional override, defaults to {SITE_URL}/checkout/cancel
PAYHERE_NOTIFY_URL=https://your-domain.com/api/payments/payhere/webhook
PAYHERE_ALERT_WEBHOOK_URL= # optional Slack/Teams incoming webhook for alerts

# (Optional) Next.js environment
NODE_ENV=development
