{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run tests/server-admin-auth.security.test.ts tests/server-user-auth.security.test.ts tests/payhere-webhook.security.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:security": "playwright test e2e/security.spec.ts",
    "test:all": "npm run test && npm run test:e2e",
    "check": "npm run typecheck && npm run test",
    "check:strict": "npm run lint && npm run typecheck && npm run test",
    "check:strict:e2e": "npm run lint && npm run typecheck && npm run test && npm run test:e2e",
    "check:strict:coverage:e2e": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:e2e",
    "security:audit": "npm audit --audit-level=high",
    "check:security": "npm run lint && npm run typecheck && npm run test:security && npm run test:e2e:security && npm run security:audit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@netlify/plugin-nextjs": "^5.15.1",
    "@next/swc-wasm-nodejs": "13.5.1",
