    "next": "^16.2.1",
    "next-themes": "^0.3.0",
    "postcss": "^8.5.8",
    "react": "18.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.53.0",
    "react-resizable-panels": "^2.1.3",
    "recharts": "^2.12.7",
